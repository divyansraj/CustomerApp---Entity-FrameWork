@model List<Transaction>

<h2>Transaction History</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Type</th>
            <th>Amount</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Type</td>
                <td>@t.Amount</td>
                <td>@t.TransactionDate</td>
            </tr>
        }
    </tbody>
</table>