@model CustomerDetailsDTO
@{
    ViewData["Title"] = "Customer Details";
}

<div class="container mt-5">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Customer Dashboard</h2>
        <a asp-action="Logout" asp-controller="Customer"
           class="btn btn-outline-secondary">
            Logout
        </a>
    </div>

    <div class="row">

        <!-- Profile Card -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Profile Information</h5>
                </div>

                <div class="card-body">
                    <p><strong>First Name:</strong> @Model.FirstName</p>
                    <p><strong>Last Name:</strong> @Model.LastName</p>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @Model.Phone</p>
                    <p><strong>Address:</strong> @Model.Address</p>

                    <div class="mt-3 d-flex gap-2">
                        <a asp-action="Edit"
                           class="btn btn-warning">
                            Edit Profile
                        </a>

                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this profile?');">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Actions Card -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Banking Services</h5>
                </div>

                <div class="card-body text-center">

                    <a asp-controller="Account"
                       asp-action="Apply"
                       class="btn btn-primary w-75 mb-3">
                        Apply for New Account
                    </a>

                    <a asp-controller="Account"
                       asp-action="MyAccounts"
                       class="btn btn-info w-75">
                        View My Accounts
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>